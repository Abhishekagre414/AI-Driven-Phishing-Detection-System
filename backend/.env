# APDS Email Configuration
# ------------------------
# Please enter the credentials for your TEST / BURNER email account below.
# DO NOT put your real personal email password here.

# The IMAP server address (e.g. imap.gmail.com)
IMAP_SERVER=imap.gmail.com

# The email address of your test account
IMAP_EMAIL=your.test.email@gmail.com

# The password (or App Password if using Gmail/Outlook)
IMAP_PASSWORD=your_app_password_here
